@model VX24TTK2.Models.Destination

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thêm điểm đến</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f5f7fb;
        }

        .card-form {
            max-width: 850px;
            margin: 40px auto;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
        }

        .header {
            background: linear-gradient(135deg,#006D77,#00A6A6);
            color: white;
            padding: 20px;
            border-radius: 20px 20px 0 0;
        }

        .btn-save {
            background: #006D77;
            color: white;
        }

            .btn-save:hover {
                background: #00515a;
                color: white;
            }
    </style>
</head>
<body>

    <div class="card card-form">

        <div class="header">
            <h3>🏝️ Thêm địa điểm du lịch</h3>
        </div>

        <div class="card-body p-4">

            <form method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Tên địa điểm</label>
                    <input type="text"
                           name="Name"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Loại địa điểm</label>

                    <select name="Type"
                            class="form-select">

                        <option>Bãi biển</option>
                        <option>Khu vui chơi</option>
                        <option>Nhà hàng</option>
                        <option>Khách sạn</option>

                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>

                    <input type="text"
                           name="Address"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả</label>

                    <textarea class="form-control"
                              rows="4"
                              name="Description"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Chi phí</label>

                    <input type="number"
                           name="Price"
                           class="form-control" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Hình ảnh</label>

                    <input type="file"
                           name="imageFile"
                           class="form-control" />
                </div>

                <button class="btn btn-save">
                    💾 Lưu địa điểm
                </button>

                <a href="/Admin/Destinations"
                   class="btn btn-secondary">
                    Quay lại
                </a>

            </form>

        </div>

    </div>

</body>
</html>