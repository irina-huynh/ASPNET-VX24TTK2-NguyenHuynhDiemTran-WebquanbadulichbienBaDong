@model List<VX24TTK2.Models.TravelCompany>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý công ty du lịch</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f5f7fb;
            font-family: Arial, sans-serif;
        }

        .page-wrap {
            max-width: 1100px;
            margin: 45px auto;
        }

        .admin-card {
            background: white;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(0,0,0,.08);
            padding: 25px;
        }

        .table th {
            background: #212529;
            color: white;
            vertical-align: middle;
        }

        .table td {
            vertical-align: middle;
        }

        .page-title {
            font-weight: 700;
            margin-bottom: 20px;
        }

        .action-btns a {
            margin-right: 5px;
            margin-bottom: 5px;
        }
    </style>
</head>

<body>

    <div class="page-wrap">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="page-title">🏢 Quản lý công ty du lịch</h2>

            <a href="/Admin/Dashboard" class="btn btn-secondary">
                ← Quay lại Dashboard
            </a>
        </div>

        <div class="admin-card">

            <div class="mb-3">
                <a href="/Admin/CreateTravelCompany" class="btn btn-success">
                    + Thêm công ty
                </a>
            </div>

            <table class="table table-bordered table-hover shadow-sm">
                <thead>
                    <tr>
                        <th style="width:70px;">ID</th>
                        <th>Tên công ty</th>
                        <th style="width:140px;">Điện thoại</th>
                        <th>Email</th>
                        <th>Website</th>
                        <th>Địa chỉ</th>
                        <th style="width:170px;">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>

                            <td>
                                <b>@item.CompanyName</b>
                            </td>

                            <td>@item.Phone</td>

                            <td>@item.Email</td>

                            <td>
                                @if (!string.IsNullOrEmpty(item.Website))
                                {
                                    <a href="@item.Website" target="_blank">
                                        @item.Website
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>

                            <td>@item.Address</td>

                            <td class="action-btns">
                                <a href="/Admin/EditTravelCompany/@item.Id"
                                   class="btn btn-warning btn-sm">
                                    Sửa
                                </a>

                                <a href="/Admin/DeleteTravelCompany/@item.Id"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bạn có chắc muốn xóa công ty này không?')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>

</body>
</html>