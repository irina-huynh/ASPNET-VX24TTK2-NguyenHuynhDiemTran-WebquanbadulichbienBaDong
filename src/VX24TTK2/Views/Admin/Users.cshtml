@model List<VX24TTK2.Models.User>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý người dùng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body style="background:#f5f7fb;">

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>👤 Quản lý người dùng</h2>

            <a href="/Admin/Dashboard" class="btn btn-secondary">
                ← Quay lại Dashboard
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <div class="card shadow border-0 rounded-4">
            <div class="card-body">

                <table class="table table-hover align-middle">
                    <thead class="table-success">
                        <tr>
                            <th>ID</th>
                            <th>Avatar</th>
                            <th>Họ tên</th>
                            <th>Tên đăng nhập</th>
                            <th>SĐT</th>
                            <th>Quyền</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th width="260">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>

                                <td>
                                    <img src="@item.Avatar"
                                         style="width:55px;height:55px;border-radius:50%;object-fit:cover;" />
                                </td>

                                <td>@item.FullName</td>
                                <td>@item.Username</td>
                                <td>@item.Phone</td>

                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">User</span>
                                    }
                                </td>

                                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>

                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-secondary">Không thể khóa</span>
                                    }
                                    else if (item.IsLocked)
                                    {
                                        <span class="badge bg-danger">Đã khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                </td>

                                <td>
                                    <a href="/Admin/UserDetail/@item.Id"
                                       class="btn btn-info btn-sm text-white">
                                        Chi tiết
                                    </a>

                                    @if (item.Role != "Admin")
                                    {
                                        if (item.IsLocked)
                                        {
                                            <a href="/Admin/ToggleLockUser/@item.Id"
                                               class="btn btn-success btn-sm">
                                                Mở khóa
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="/Admin/ToggleLockUser/@item.Id"
                                               class="btn btn-warning btn-sm">
                                                Khóa
                                            </a>
                                        }

                                        <a href="/Admin/DeleteUser/@item.Id"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Bạn có chắc muốn xóa người dùng này không?')">
                                            Xóa
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Không thao tác</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

    </div>

</body>
</html>