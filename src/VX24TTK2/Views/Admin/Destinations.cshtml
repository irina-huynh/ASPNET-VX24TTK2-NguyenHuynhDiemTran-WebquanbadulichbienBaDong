@model IEnumerable<VX24TTK2.Models.Destination>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý điểm đến</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body style="background:#f5f7fb;">

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>🏝️ Quản lý điểm đến</h2>

            <a href="/Admin/CreateDestination"
               class="btn btn-success">
                + Thêm điểm đến
            </a>
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-body">

                <table class="table table-hover align-middle">
                    <thead class="table-info">
                        <tr>
                            <th>ID</th>
                            <th>Ảnh</th>
                            <th>Tên</th>
                            <th>Loại</th>
                            <th>Giá</th>
                            <th width="170">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>

                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             width="110"
                                             height="70"
                                             style="object-fit:cover;border-radius:10px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có ảnh</span>
                                    }
                                </td>

                                <td>@item.Name</td>
                                <td>@item.Type</td>

                                <td>
                                    @if (item.Price == 0)
                                    {
                                        <span class="text-success fw-bold">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">@item.Price.ToString("N0") đ</span>
                                    }
                                </td>

                                <td width="170">
                                    <a href="/Admin/EditDestination/@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                                    <a href="/Admin/DeleteDestination/@item.Id"
                                       onclick="return confirm('Bạn có chắc muốn xóa điểm đến này không?')"
                                       class="btn btn-danger btn-sm">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <a href="/Admin/Dashboard"
                   class="btn btn-secondary">
                    Quay lại Dashboard
                </a>

            </div>
        </div>

    </div>

</body>
</html>