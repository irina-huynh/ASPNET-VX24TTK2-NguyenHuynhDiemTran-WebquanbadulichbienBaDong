@model IEnumerable<VX24TTK2.Models.TourSchedule>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý lịch trình</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>
<body style="background:#f5f7fb;">

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>🗓️ Quản lý lịch trình</h2>

            @Html.ActionLink("+ Thêm lịch trình", "CreateTourSchedule", "Admin", null, new { @class = "btn btn-success" })
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-body">

                <table class="table table-hover align-middle">
                    <thead class="table-success">
                        <tr>
                            <th>ID</th>
                            <th>Tiêu đề</th>
                            <th>Ngày</th>
                            <th>Thời gian</th>
                            <th>Nội dung</th>
                            <th width="180">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Title</td>
                                <td>Ngày @item.DayNumber</td>
                                <td>@item.TimeText</td>
                                <td>@item.Description</td>
                                <td>
                                    @Html.ActionLink("Sửa", "EditTourSchedule", "Admin", new { id = item.Id }, new { @class = "btn btn-warning btn-sm" })

                                    @Html.ActionLink("Xóa", "DeleteTourSchedule", "Admin", new { id = item.Id }, new { @class = "btn btn-danger btn-sm", onclick = "return confirm('Bạn có chắc muốn xóa lịch trình này không?')" })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <a href="/Admin/Dashboard"
                   class="btn btn-secondary">
                    Quay lại Dashboard
                </a>

            </div>
        </div>

    </div>

</body>
</html>