@model VX24TTK2.Models.TourSchedule

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Sửa lịch trình</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>
<body style="background:#f5f7fb;">

    <div class="card shadow border-0 rounded-4"
         style="max-width:850px;margin:40px auto;">

        <div class="card-header text-white"
             style="background:linear-gradient(135deg,#F4A261,#E76F51);border-radius:18px 18px 0 0;">
            <h3>✏️ Sửa lịch trình tham quan</h3>
        </div>

        <div class="card-body p-4">

            <form method="post">

                @Html.HiddenFor(x => x.Id)

                <div class="mb-3">
                    <label class="form-label">Tiêu đề tour</label>
                    @Html.TextBoxFor(x => x.Title,
                        new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Ngày số</label>
                    @Html.TextBoxFor(x => x.DayNumber,
                        new { @class = "form-control", type = "number" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Thời gian</label>
                    @Html.TextBoxFor(x => x.TimeText,
                        new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Nội dung lịch trình</label>
                    @Html.TextAreaFor(x => x.Description,
                        new { @class = "form-control", rows = 4 })
                </div>

                <button class="btn btn-warning text-white">
                    💾 Cập nhật
                </button>

                <a href="/Admin/TourSchedules"
                   class="btn btn-secondary">
                    Quay lại
                </a>

            </form>

        </div>
    </div>

</body>
</html>