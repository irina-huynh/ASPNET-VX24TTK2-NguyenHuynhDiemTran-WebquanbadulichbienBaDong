@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Dashboard Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body style="background:#f5f7fb; font-family:Arial;">

    <div class="container mt-5" style="max-width:1200px;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Dashboard Admin</h2>
                <p class="text-muted">Xin chào Admin 👋</p>
            </div>

            <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger">
                Đăng xuất
            </a>
        </div>

        <div class="row g-4 mb-5">

            <div class="col-md-4">
                <div class="card border-0 shadow rounded-4 text-white"
                     style="background:#00747A;">
                    <div class="card-body p-4">
                        <h3>@ViewBag.TotalDestinations</h3>
                        <p class="mb-0">Điểm đến</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow rounded-4 text-white"
                     style="background:#00A6A6;">
                    <div class="card-body p-4">
                        <h3>@ViewBag.TotalReviews</h3>
                        <p class="mb-0">Đánh giá</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow rounded-4"
                     style="background:#F6BD60;">
                    <div class="card-body p-4">
                        <h3>@ViewBag.AverageRating</h3>
                        <p class="mb-0">Sao trung bình</p>
                    </div>
                </div>
            </div>


        </div>

        <div class="card border-0 shadow rounded-4 mt-5">
            <div class="card-body p-4">

                <h4 class="mb-4">Quản lý hệ thống</h4>

                <div class="row g-3">

                    <div class="col-md-4">
                        <a href="/Admin/Destinations"
                           class="btn btn-primary w-100 py-3">
                            🏝️ Quản lý Điểm đến
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/Admin/TourSchedules"
                           class="btn btn-success w-100 py-3">
                            🗓️ Quản lý Lịch trình
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/Admin/Reviews"
                           class="btn btn-warning text-white w-100 py-3">
                            ⭐ Quản lý Đánh giá
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/Admin/TravelCompanies"
                           class="btn btn-info text-white w-100 py-3">
                            🏢 Quản lý Công ty du lịch
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/Admin/Users"
                           class="btn btn-dark w-100 py-3">
                            👥 Quản lý người dùng
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>

</body>
</html>