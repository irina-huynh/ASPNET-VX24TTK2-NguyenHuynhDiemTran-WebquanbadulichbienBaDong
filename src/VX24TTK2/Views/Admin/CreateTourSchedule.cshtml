@model VX24TTK2.Models.TourSchedule

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thêm lịch trình</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>
<body style="background:#f5f7fb;">

    <div class="card shadow border-0 rounded-4"
         style="max-width:850px;margin:40px auto;">

        <div class="card-header text-white"
             style="background:linear-gradient(135deg,#006D77,#00A6A6);border-radius:18px 18px 0 0;">
            <h3>🗓️ Thêm lịch trình tham quan</h3>
        </div>

        <div class="card-body p-4">

            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Tiêu đề tour</label>
                    <input name="Title" class="form-control"
                           placeholder="Ví dụ: Tour Ba Động 1 ngày" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ngày số</label>
                    <input name="DayNumber" type="number"
                           class="form-control"
                           placeholder="Ví dụ: 1" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Thời gian</label>
                    <input name="TimeText" class="form-control"
                           placeholder="Ví dụ: 07:00 - 08:30" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Nội dung lịch trình</label>
                    <textarea name="Description"
                              rows="4"
                              class="form-control"></textarea>
                </div>

                <button class="btn btn-success">
                    💾 Lưu lịch trình
                </button>

                <a href="/Admin/TourSchedules"
                   class="btn btn-secondary">
                    Quay lại
                </a>

            </form>

        </div>
    </div>

</body>
</html>