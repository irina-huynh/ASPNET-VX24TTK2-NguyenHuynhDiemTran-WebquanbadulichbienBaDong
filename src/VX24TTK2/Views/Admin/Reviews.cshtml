@model IEnumerable<VX24TTK2.Models.CustomerReview>

@{
    Layout = null;
    double avg = Model.Any() ? Model.Average(x => x.Rating) : 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý đánh giá</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>
<body style="background:#f5f7fb;">

    <div class="container mt-5">

        <h2>⭐ Quản lý đánh giá khách hàng</h2>

        <div class="alert alert-warning mt-3">
            <b>Số sao trung bình:</b> @avg.ToString("0.0") / 5
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-body">

                <table class="table table-hover align-middle">
                    <thead class="table-warning">
                        <tr>
                            <th>ID</th>
                            <th>Người dùng</th>
                            <th>Điểm đến</th>
                            <th>Sao</th>
                            <th>Bình luận</th>
                            <th>Ngày gửi</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    @(item.User != null ? item.User.FullName : "")
                                </td>

                                <td>
                                    @(item.Destination != null ? item.Destination.Name : "")
                                </td>
                                <td style="color:#f5a400;font-size:20px;">
                                    @for (int i = 1; i <= item.Rating; i++)
                                    {
                                        @:★
                                    }
                                </td>
                                <td>

                                    <p>@item.Comment</p>

                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             style="width:120px;
                    border-radius:10px;" />
                                    }

                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a href="/Admin/DeleteReview/@item.Id"
                                       onclick="return confirm('Bạn có chắc muốn xóa đánh giá này không?')"
                                       class="btn btn-danger btn-sm">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <a href="/Admin/Dashboard" class="btn btn-secondary">
                    Quay lại Dashboard
                </a>

            </div>
        </div>

    </div>

</body>
</html>