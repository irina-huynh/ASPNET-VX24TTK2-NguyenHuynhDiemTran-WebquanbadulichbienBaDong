@model VX24TTK2.Models.Destination

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Sửa địa điểm</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f5f7fb;
        }

        .card-form {
            max-width: 900px;
            margin: 40px auto;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
        }

        .header {
            background: linear-gradient(135deg,#F4A261,#E76F51);
            color: white;
            padding: 20px;
            border-radius: 20px 20px 0 0;
        }

        .preview-image {
            width: 220px;
            height: 140px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid #ddd;
        }

        .btn-update {
            background: #E76F51;
            color: white;
        }

            .btn-update:hover {
                background: #d65c3f;
                color: white;
            }
    </style>
</head>
<body>

    <div class="card card-form">

        <div class="header">
            <h3>✏️ Sửa địa điểm du lịch</h3>
        </div>

        <div class="card-body p-4">

            <form method="post" enctype="multipart/form-data">

                @Html.HiddenFor(x => x.Id)

                <div class="row">

                    <div class="col-md-8">

                        <div class="mb-3">
                            <label class="form-label">Tên địa điểm</label>
                            @Html.TextBoxFor(x => x.Name,
                                new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Loại địa điểm</label>

                            <select name="Type" class="form-select">

                                <option @(Model.Type == "Bãi biển" ? "selected" : "")>
                                    Bãi biển
                                </option>

                                <option @(Model.Type == "Khu vui chơi" ? "selected" : "")>
                                    Khu vui chơi
                                </option>

                                <option @(Model.Type == "Nhà hàng" ? "selected" : "")>
                                    Nhà hàng
                                </option>

                                <option @(Model.Type == "Khách sạn" ? "selected" : "")>
                                    Khách sạn
                                </option>

                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ</label>

                            @Html.TextBoxFor(x => x.Address,
                                new { @class = "form-control" })
                        </div>

                    </div>

                    <div class="col-md-4 text-center">

                        <label class="form-label">Ảnh hiện tại</label>

                        <br />

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl"
                                 class="preview-image" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/220x140"
                                 class="preview-image" />
                        }

                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả</label>

                    @Html.TextAreaFor(x => x.Description,
                        new
                        {
                            @class = "form-control",
                            rows = 4
                        })
                </div>

                <div class="mb-3">
                    <label class="form-label">Chi phí</label>

                    @Html.TextBoxFor(x => x.Price,
                        new
                        {
                            @class = "form-control",
                            type = "number"
                        })
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        Đổi ảnh mới (không bắt buộc)
                    </label>

                    <input type="file"
                           name="imageFile"
                           class="form-control" />
                </div>

                <button class="btn btn-update">
                    💾 Cập nhật
                </button>

                <a href="/Admin/Destinations"
                   class="btn btn-secondary">
                    Quay lại
                </a>

            </form>

        </div>

    </div>

</body>
</html>