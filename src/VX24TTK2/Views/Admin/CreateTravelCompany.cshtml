@model VX24TTK2.Models.TravelCompany

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thêm công ty du lịch</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body style="background:#f5f7fb;">

    <div class="card shadow border-0 rounded-4"
         style="max-width:850px;margin:40px auto;">

        <div class="card-header text-white"
             style="background:linear-gradient(135deg,#006D77,#00A6A6);border-radius:18px 18px 0 0;">
            <h3>🏢 Thêm công ty du lịch</h3>
        </div>

        <div class="card-body p-4">

            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Tên công ty</label>
                    <input name="CompanyName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input name="Phone" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input name="Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Website</label>
                    <input name="Website" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <input name="Address" class="form-control" />
                </div>

                <button class="btn btn-success">
                    💾 Lưu công ty
                </button>

                <a href="/Admin/TravelCompanies" class="btn btn-secondary">
                    Quay lại
                </a>

            </form>

        </div>
    </div>

</body>
</html>