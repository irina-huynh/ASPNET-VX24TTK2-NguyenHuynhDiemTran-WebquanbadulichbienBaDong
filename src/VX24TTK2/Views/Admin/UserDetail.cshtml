@model VX24TTK2.Models.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Chi tiết người dùng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body style="background:#f5f7fb;">

    <div class="container mt-5" style="max-width:800px;">

        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4">

                <h2 class="mb-4">👤 Chi tiết người dùng</h2>

                <div class="d-flex align-items-center mb-4">
                    <img src="@Model.Avatar"
                         style="width:110px;height:110px;border-radius:50%;object-fit:cover;margin-right:25px;" />

                    <div>
                        <h4>@Model.FullName</h4>
                        <p class="mb-1">Tên đăng nhập: <b>@Model.Username</b></p>
                        <p class="mb-1">Số điện thoại: @Model.Phone</p>
                        <p class="mb-1">Quyền: @Model.Role</p>

                        <p>
                            Trạng thái:
                            @if (Model.Role == "Admin")
                            {
                                <span class="badge bg-secondary">Không thể khóa</span>
                            }
                            else if (Model.IsLocked)
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </p>

                        <p>Ngày tạo: @Model.CreatedDate.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>

                <a href="/Admin/Users" class="btn btn-secondary">
                    ← Quay lại danh sách
                </a>

            </div>
        </div>

    </div>

</body>
</html>