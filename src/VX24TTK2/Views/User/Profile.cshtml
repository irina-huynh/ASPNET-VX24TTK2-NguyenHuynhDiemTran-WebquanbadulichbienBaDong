@model VX24TTK2.Models.User

@{
    ViewBag.Title = "Hồ sơ cá nhân";
}

<div class="container mt-5" style="max-width:800px;">

    <div class="card shadow border-0 rounded-4">

        <div class="card-body p-4">

            <h2 class="mb-4">👤 Hồ sơ cá nhân</h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form action="/User/UpdateProfile"
                  method="post"
                  enctype="multipart/form-data">

                <div class="text-center mb-4">
                    <img src="@Model.Avatar"
                         style="width:130px;height:130px;border-radius:50%;object-fit:cover;"
                         class="border shadow-sm" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ảnh đại diện</label>
                    <input type="file"
                           name="avatarFile"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Họ tên</label>
                    <input type="text"
                           name="fullName"
                           value="@Model.FullName"
                           class="form-control"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <input type="text"
                           value="@Model.Username"
                           class="form-control"
                           readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input type="text"
                           name="phone"
                           value="@Model.Phone"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Quyền</label>
                    <input type="text"
                           value="@Model.Role"
                           class="form-control"
                           readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ngày tạo</label>
                    <input type="text"
                           value="@Model.CreatedDate.ToString("dd/MM/yyyy")"
                           class="form-control"
                           readonly />
                </div>

                <button type="submit" class="btn btn-warning">
                    Cập nhật thông tin
                </button>

                <a href="/Home" class="btn btn-secondary">
                    Quay lại trang chủ
                </a>

            </form>

        </div>

    </div>

</div>