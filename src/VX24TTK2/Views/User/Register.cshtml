@model VX24TTK2.Models.User

<div class="container mt-5" style="max-width:600px;">
    <div class="card shadow border-0 p-4">
        <h2 class="mb-4">Đăng ký tài khoản</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post" enctype="multipart/form-data">
            <label>Họ tên</label>
            <input name="FullName" class="form-control mb-3" required />

            <label>Tên đăng nhập</label>
            <input name="Username" class="form-control mb-3" required />

            <label>Số điện thoại</label>
            <input name="Phone" class="form-control mb-3" />

            <label>Mật khẩu</label>
            <input name="Password" type="password" class="form-control mb-3" required />

            <label>Nhập lại mật khẩu</label>
            <input name="confirmPassword" type="password" class="form-control mb-3" required />

            <label>Ảnh đại diện</label>
            <input name="avatarFile" type="file" class="form-control mb-4" />

            <button class="btn btn-primary w-100">Đăng ký</button>
        </form>

        <p class="mt-3 text-center">
            Đã có tài khoản?
            <a href="/Account/Login">Đăng nhập</a>
        </p>
    </div>
</div>