@model List<VX24TTK2.Models.CustomerReview>

<div class="container mt-5">

    <h2>⭐ Đánh giá du lịch</h2>

    @if (Session["UserId"] == null)
    {
        <div class="alert alert-warning">
            Bạn cần đăng nhập để gửi đánh giá.
           <a href="/Account/Login">Đăng nhập ngay</a>
        </div>
    }
    else
    {
        <form method="post" enctype="multipart/form-data" class="mb-5">

            <select name="DestinationId" class="form-control mb-2">
                <option value="1">Bãi biển Ba Động</option>
                <option value="2">Khu cắm trại ven biển</option>
                <option value="3">Hàng dương Ba Động</option>
                <option value="4">Nhà hàng Hải Sản Ba Động</option>
                <option value="8">Lễ hội Ok Om Bok</option>
            </select>

            <select name="Rating" class="form-control mb-2">
                <option value="5">⭐⭐⭐⭐⭐</option>
                <option value="4">⭐⭐⭐⭐</option>
                <option value="3">⭐⭐⭐</option>
                <option value="2">⭐⭐</option>
                <option value="1">⭐</option>
            </select>

            <textarea name="Comment"
                      class="form-control mb-2"
                      placeholder="Chia sẻ trải nghiệm của bạn"></textarea>

            <input type="file"
                   name="imageFile"
                   class="form-control mb-3" />

            <button class="btn btn-warning">
                Gửi đánh giá
            </button>

        </form>
    }

    <hr />

    @foreach (var item in Model)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-body">

               <div class="d-flex align-items-center mb-2">

    <img src="@(item.User != null ? item.User.Avatar : "/Content/Uploads/default-user.png")"
         style="width:55px;
                height:55px;
                border-radius:50%;
                object-fit:cover;
                margin-right:12px;" />

    <div>
        <h5 class="mb-0">
            @(item.User != null ? item.User.FullName : "Khách du lịch")
        </h5>

        <small class="text-muted">
            @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </small>
    </div>

</div>

                <p class="text-muted">
                    Điểm đến:
                    @(item.Destination != null ? item.Destination.Name : "")
                </p>

                <p style="font-size:22px;color:orange">
                    @for (int i = 1; i <= item.Rating; i++)
                    {
                        <span>★</span>
                    }

                    @for (int i = item.Rating + 1; i <= 5; i++)
                    {
                        <span style="color:#ddd;">★</span>
                    }
                </p>

                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl"
                         style="max-width:300px;border-radius:12px;margin-bottom:10px;" />
                }

                <p>@item.Comment</p>

                <small class="text-muted">
                    Ngày đăng: @item.CreatedAt.ToString("dd/MM/yyyy")
                </small>

            </div>
        </div>
    }

</div>