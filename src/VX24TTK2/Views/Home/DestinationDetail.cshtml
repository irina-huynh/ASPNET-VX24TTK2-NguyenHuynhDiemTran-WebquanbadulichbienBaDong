@model VX24TTK2.Models.Destination

@*
    Chức năng:
    Hiển thị chi tiết một địa điểm 

   
*@

@{
    ViewBag.Title = Model.Name;
}

<div class="container mt-5">

    <div class="card shadow border-0 rounded-4">

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl"
                 style="height:450px;object-fit:cover;"
                 class="card-img-top">
        }

        <div class="card-body p-4">

            <h1 class="mb-3">
                @Model.Name
            </h1>

            <span class="badge bg-info">
                @Model.Type
            </span>

            <hr />

            <h4>📍 Địa chỉ</h4>

            <p>
                @Model.Address
            </p>

            <h4>💰 Chi phí</h4>

            <p>
                <strong>Giá:</strong>

                @if (Model.Price == 0)
                {
                    <span style="color:green;font-weight:bold">
                        Miễn phí
                    </span>
                }
                else
                {
                    <span>
                        @Model.Price.ToString("N0") đ
                    </span>
                }
            </p>

            <h4>📖 Giới thiệu</h4>

            <p style="text-align:justify;">
                @Model.Description
            </p>

            <h4 class="mt-4">✨ Hoạt động nổi bật</h4>

            <ul>
                <li>Tắm biển và thư giãn</li>
                <li>Chụp ảnh check-in</li>
                <li>Khám phá cảnh quan địa phương</li>
                <li>Thưởng thức ẩm thực đặc sản</li>
            </ul>

            <h4 class="mt-4">🗺️ Vị trí trên bản đồ</h4>

            <iframe src="https://www.google.com/maps?q=Biển%20Ba%20Động%20Trà%20Vinh&output=embed"
                    width="100%"
                    height="450"
                    style="border:0;border-radius:15px;"
                    loading="lazy">
            </iframe>

            <div class="mt-4">

                <a href="/Home/Destinations"
                   class="btn btn-secondary">
                    ← Quay lại
                </a>

            </div>

        </div>

    </div>

</div>