@model List<VX24TTK2.Models.Destination>



@{
    ViewBag.Title = "Du lịch Biển Ba Động";
    var reviews = ViewBag.RecentReviews as List<VX24TTK2.Models.CustomerReview>;
}

<style>
    .hero-badong {
        min-height: 520px;
        background: linear-gradient(rgba(0, 70, 80, .45), rgba(0, 70, 80, .55)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e');
        background-size: cover;
        background-position: center;
        border-radius: 0 0 40px 40px;
        color: white;
        display: flex;
        align-items: center;
    }

        .hero-badong h1 {
            font-size: 64px;
            font-weight: 800;
        }

    .section-title {
        font-weight: 800;
        color: #073B4C;
    }

    .tour-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: .25s;
    }

        .tour-card:hover {
            transform: translateY(-6px);
        }

    .tour-img {
        height: 210px;
        object-fit: cover;
        background: linear-gradient(135deg,#BEE9E8,#00A6A6);
    }

    .badge-type {
        background: #E7F6F7;
        color: #006D77;
        padding: 6px 12px;
        border-radius: 30px;
        font-weight: 600;
    }

    .price {
        color: #E76F51;
        font-weight: 800;
        font-size: 18px;
    }

    .info-box {
        background: #F7FBFC;
        border-radius: 24px;
        padding: 30px;
        height: 100%;
    }

    .intro-box {
        background: white;
        border-radius: 28px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        text-align: justify;
        line-height: 1.8;
    }

    .carousel-control-prev,
    .carousel-control-next {
        width: 45px;
    }

    .carousel-control-prev {
        left: -55px;
    }

    .carousel-control-next {
        right: -55px;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: #073B4C;
        border-radius: 50%;
        padding: 20px;
    }

    .tour-img {
        height: 210px;
        width: 100%;
        object-fit: cover;
        border-radius: 22px 22px 0 0;
    }
</style>

<section class="hero-badong">
    <div class="container">
        <div class="col-md-8">
            <p class="fw-bold text-uppercase">Du lịch Trà Vinh</p>
            <h1>Khám phá Biển Ba Động</h1>
            <p class="lead">
                Tận hưởng không gian biển yên bình, vẻ đẹp hoang sơ,
                hải sản địa phương và các hoạt động trải nghiệm gần gũi thiên nhiên.
            </p>

            <a href="/Home/Destinations" class="btn btn-warning btn-lg mt-3">
                Khám phá ngay
            </a>

            <a href="/Home/Schedules" class="btn btn-outline-light btn-lg mt-3 ms-2">
                Gợi ý tham quan
            </a>
        </div>
    </div>
</section>

<div class="container mt-5">

    <div class="intro-box mb-5">
        <h2 class="section-title mb-4">Giới thiệu Biển Ba Động</h2>

        <p>
            Biển Ba Động là một trong những điểm du lịch nổi tiếng của tỉnh Trà Vinh,
            nằm tại xã Trường Long Hòa, thị xã Duyên Hải và cách trung tâm thành phố
            Trà Vinh khoảng 55 km. Đây là một trong số ít bãi biển của khu vực Đồng bằng
            sông Cửu Long còn giữ được nét hoang sơ, yên bình và gần gũi với thiên nhiên.
        </p>

        <p>
            Tên gọi "Ba Động" xuất phát từ hiện tượng tự nhiên khi gió biển kết hợp
            với cát tạo thành các động cát nhấp nhô ven bờ. Với bãi biển rộng,
            hàng dương xanh mát và không khí trong lành, nơi đây là điểm đến phù hợp
            cho du khách muốn thư giãn, tắm biển, cắm trại và ngắm cảnh biển.
        </p>

        <p>
            Mặc dù chưa phát triển du lịch mạnh như nhiều địa phương ven biển khác,
            Biển Ba Động vẫn thu hút du khách bởi vẻ đẹp mộc mạc, không gian yên tĩnh,
            hải sản địa phương và sự thân thiện của người dân. Đây là địa điểm thích hợp
            cho gia đình, nhóm bạn và những người yêu thích khám phá thiên nhiên.
        </p>
    </div>

    <div class="row mt-5 mb-5">
        <div class="col-md-3 mb-3">
            <div class="card shadow border-0 text-center info-box">
                <h1>🏖️</h1>
                <h5>Bãi biển hoang sơ</h5>
                <p>Không gian yên bình, thích hợp tắm biển và nghỉ ngơi.</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow border-0 text-center info-box">
                <h1>🍤</h1>
                <h5>Hải sản địa phương</h5>
                <p>Các món ăn ven biển dân dã, tươi ngon và gần gũi.</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow border-0 text-center info-box">
                <h1>⛺</h1>
                <h5>Cắm trại ven biển</h5>
                <p>Hoạt động phù hợp cho nhóm bạn và gia đình.</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow border-0 text-center info-box">
                <h1>🎉</h1>
                <h5>Lễ hội Khmer</h5>
                <p>Có thể kết hợp tham quan các lễ hội văn hóa tại Trà Vinh.</p>
            </div>
        </div>
    </div>

    <h2 class="section-title mb-4">Điểm đến nổi bật</h2>

    <div id="destinationCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">

            @{
                var places = Model.ToList();
                int groupSize = 4;
                int totalGroups = (int)Math.Ceiling((double)places.Count / groupSize);
            }

            @for (int g = 0; g < totalGroups; g++)
            {
                var group = places.Skip(g * groupSize).Take(groupSize).ToList();

                <div class="carousel-item @(g == 0 ? "active" : "")">
                    <div class="row">
                        @foreach (var item in group)
                        {
                            <div class="col-md-3 mb-4">
                                <div class="card tour-card shadow">

                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="card-img-top tour-img" />
                                    }
                                    else
                                    {
                                        <div class="tour-img d-flex align-items-center justify-content-center text-white fw-bold">
                                            @item.Type
                                        </div>
                                    }

                                    <div class="card-body">
                                        <span class="badge-type">@item.Type</span>

                                        <h5 class="mt-3 fw-bold">@item.Name</h5>

                                        <p class="text-muted">@item.Address</p>

                                        <p class="price">
                                            @(item.Price == 0 ? "Miễn phí" : item.Price.ToString("N0") + " đ")
                                        </p>

                                        <a href="/Home/DestinationDetail/@item.Id"
                                           class="btn btn-primary w-100">
                                            Xem chi tiết
                                        </a>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button"
                data-bs-target="#destinationCarousel"
                data-bs-slide="prev">
            <span class="carousel-control-prev-icon bg-dark rounded-circle"></span>
        </button>

        <button class="carousel-control-next" type="button"
                data-bs-target="#destinationCarousel"
                data-bs-slide="next">
            <span class="carousel-control-next-icon bg-dark rounded-circle"></span>
        </button>
    </div>

    <h2 class="section-title mt-5 mb-4">Đánh giá mới nhất</h2>

    <div class="row">
        @if (reviews != null && reviews.Any())
        {
            foreach (var item in reviews)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow border-0">
                        <div class="card-body">
                           <h5>@(item.User != null ? item.User.FullName : "Khách du lịch")</h5>

                            <p style="font-size:20px;color:orange;">
                                @for (int i = 1; i <= item.Rating; i++)
                                {
                                    <span>★</span>
                                }

                                @for (int i = item.Rating + 1; i <= 5; i++)
                                {
                                    <span style="color:#ddd;">★</span>
                                }
                            </p>

                            <p>@item.Comment</p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Chưa có đánh giá nào.</p>
        }
    </div>
</div>

<section class="mt-5 py-5" style="background:#073B4C;color:white;">
    <div class="container text-center">
        <h2 class="fw-bold">Sẵn sàng khám phá Biển Ba Động?</h2>
        <p class="lead">
            Xem thông tin điểm đến, gợi ý tham quan, công ty du lịch liên kết và gửi đánh giá trải nghiệm của bạn.
        </p>

        <a href="/Home/Schedules" class="btn btn-warning">
            Xem gợi ý tham quan
        </a>

        <a href="/Home/Contact" class="btn btn-outline-light ms-2">
            Xem thông tin liên hệ
        </a>
    </div>
</section>